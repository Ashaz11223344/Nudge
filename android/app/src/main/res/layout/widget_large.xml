<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/floral_white"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_quote_text"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Your limitation—it's only your imagination."
            android:textColor="@color/charcoal_brown"
            android:textSize="20sp"
            android:textStyle="italic"
            android:gravity="center"
            android:maxLines="6"
            android:ellipsize="end" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dust_grey"
            android:layout_marginVertical="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STREAK"
                    android:textColor="@color/dust_grey"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/widget_streak_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 Days"
                    android:textColor="@color/spicy_paprika"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MOOD"
                    android:textColor="@color/dust_grey"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/widget_mood_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feeling Great"
                    android:textColor="@color/charcoal_brown"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/widget_refresh_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_rotate"
                android:tint="@color/spicy_paprika"
                android:contentDescription="Refresh Quote" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
