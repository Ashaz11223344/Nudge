# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats so focal can improve the tool.
# For more information, see https://guides.cocoapods.org/plugin/focal.html
# To disable networking, uncomment the next line.
# ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

def flutter_root
  # 1. Check environment variable (highest priority for CI)
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT'] && !ENV['FLUTTER_ROOT'].empty?

  # 2. Check Generated.xcconfig (standard for local development)
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.readlines(generated_xcode_build_settings_path).each do |line|
      matches = line.match(/FLUTTER_ROOT=(.*)/)
      return matches[1].strip if matches
    end
  end

  # 3. Dynamic fallback using 'which flutter'
  flutter_bin = `which flutter`.strip
  return File.dirname(File.dirname(flutter_bin)) unless flutter_bin.empty?

  raise "FLUTTER_ROOT not found. Ensure Flutter is installed and in your PATH."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do

  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
